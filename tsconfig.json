{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",           
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true        
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "tests"]
}